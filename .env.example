# Database Configuration
DATABASE_URL=postgresql://postgres:Aniket@12@localhost:5432/business_discovery_outreach

# SMTP / Email Configuration (Nodemailer)
# If these are left blank, Nodemailer will automatically generate an Ethereal test account and print preview links.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Twilio Configuration (SMS & WhatsApp)
# If these are left blank, Twilio dispatches will be simulated in the console logs.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
